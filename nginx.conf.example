# put this file in /etc/nginx/conf.d/warehouse.conf
upstream puma_server {
    server unix:/tmp/warehouse.sock fail_timeout=0;
}

server {
    server_name         [DOMAIN NAME HERE];
    ssl_certificate     /path/to/ssl.crt;
    ssl_certificate_key /path/to/ssl.key;

    root /home/user/warehouse/public;
    # it's strongly recommended to only expose this port on the tailscale network, not the public internet.
    # if you run `ifconfig` and look for the tailscale interface, you can see the IP address of your
    # machine on the tailscale network. use that IP address in place of 100.xxx.yyy.zzz below.
    listen 100.xxx.yyy.zzz:20600 ssl;
    # if you need to access the server publicly, use `rake server:funnel` to forward this port to the
    # public internet. it's strongly recommended to only do this temporarily, for example to sync
    # your music library to the apple watch app (which does not support tailscale), rather than
    # having the app publicly available always.
    # this is a plain-http listener (no `ssl`): funnel terminates tls on the public port 443 and
    # forwards plain http here. keep it on a dedicated port like 20601 so it can't collide with any
    # real https-on-443 server block on the box.
    listen 127.0.0.1:20601;
    client_max_body_size 1G;
    keepalive_timeout 5;

    location ^~ /api/ {
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_pass http://puma_server;
        proxy_max_temp_file_size 0;
        proxy_read_timeout 600;
        proxy_send_timeout 600;
        proxy_buffering off;
    }

    location ^~ /music/ {
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_pass http://puma_server;
        proxy_max_temp_file_size 0;
        proxy_read_timeout 600;
        proxy_send_timeout 600;
        proxy_buffering off;
    }

    location ^~ /artwork/ {
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_pass http://puma_server;
        proxy_max_temp_file_size 0;
        proxy_read_timeout 600;
        proxy_send_timeout 600;
        proxy_buffering off;
    }

    location = / {
        try_files /index.html =404;
    }

    location / {
        try_files $uri =404;
    }

    location ^~ /accel/music/ {
        alias /home/user/warehouse/music/;
        internal;
    }

    location ^~ /accel/artwork/ {
        alias /home/user/warehouse/artwork/;
        internal;
    }
}
